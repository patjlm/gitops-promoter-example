# gitops-promoter local setup configuration
# Copy this file to config.local.env and edit values before running setup.sh

# GitHub App credentials (required)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_FILE=  # path to .pem file

# gitops-promoter image (override to test custom builds / PR branches)
PROMOTER_IMAGE=quay.io/argoprojlabs/gitops-promoter
PROMOTER_TAG=v0.27.1

# Install from a release manifest URL, or leave empty to use PROMOTER_IMAGE/TAG
# Example for a specific release:
#   PROMOTER_INSTALL_URL=https://github.com/argoproj-labs/gitops-promoter/releases/download/v0.27.1/install.yaml
# Leave empty to build/load a custom image instead:
PROMOTER_INSTALL_URL=https://github.com/argoproj-labs/gitops-promoter/releases/download/v0.27.1/install.yaml

# Minikube profile name
MINIKUBE_PROFILE=promoter-example
